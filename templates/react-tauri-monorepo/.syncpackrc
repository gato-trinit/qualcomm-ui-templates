{
  "$schema": "./node_modules/syncpack/schema.json",
  "versionGroups": [
    {
      "label": "Ignore workspace dependencies",
      "isIgnored": true,
      "dependencies": ["$LOCAL"],
      "dependencyTypes": ["prod", "dev"]
    },
    {
      "label": "Ignore peerDependencies",
      "dependencyTypes": ["peer"],
      "isIgnored": true
    },
    {
      "label": "Highest semver",
      "preferVersion": "highestSemver",
      "dependencyTypes": ["dev", "prod"]
    }
  ],
  "sortAz": [],
  "sortFirst": [
    "name",
    "displayName",
    "version",
    "private",
    "description",
    "categories",
    "keywords",
    "homepage",
    "bugs",
    "license",
    "author",
    "maintainers",
    "contributors",
    "repository",
    "funding",
    "bin",
    "directories",
    "workspaces",
    "files",
    "os",
    "cpu",
    "type",
    "sideEffects",
    "main",
    "module",
    "browser",
    "types",
    "imports",
    "exports",
    "publishConfig",
    "scripts",
    "dependencies",
    "devDependencies",
    "peerDependencies",
    "peerDependenciesMeta",
    "optionalDependencies",
    "bundledDependencies",
    "overrides",
    "simple-git-hooks",
    "vite-staged",
    "lint-staged",
    "nano-staged",
    "commitlint",
    "contributes",
    "activationEvents",
    "icon",
    "browserslist",
    "prettier",
    "eslintConfig",
    "jest",
    "c8",
    "engines",
    "packageManager",
    "pnpm",
    "customField",
    "myConfig",
    "_internal",
    "_private"
  ]
}
