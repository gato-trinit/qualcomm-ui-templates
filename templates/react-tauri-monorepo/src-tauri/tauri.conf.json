{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "react-tauri-monorepo",
  "version": "0.1.0",
  "identifier": "com.qualcomm.react-tauri-monorepo",
  "build": {
    "beforeDevCommand": "pnpm --filter @project/react-app dev:site",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../packages/react-app/dist"
  },
  "app": {
    "windows": [
      {
        "title": "My App",
        "width": 1200,
        "height": 800,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
