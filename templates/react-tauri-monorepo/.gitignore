dist/
build/
out/
out-tsc/
bundle-size-dist/
temp/
tmp/
.sst/
.build/
.turbo/
**/.turbo/**
.turbo-cache/*
!.turbo-cache/.gitkeep
.nx/cache/
.nx/workspace-data/
_cdk.context.json
.cdk.context.json
packages/**/stats.yml
packages/**/meta.json
*-unpacked/

