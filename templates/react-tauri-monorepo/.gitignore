###############################################################################
# Angular
**/.angular/

# SvelteKit
**/*.svelte-kit/output

###############################################################################
# Documentation & static-site tooling
###############################################################################
packages/**/build
packages/**/generated/**
!packages/**/generated/.gitkeep
packages/**/src/doc-props.json
.typedoc

###############################################################################
# Environment / secrets
###############################################################################
.env*
**/certs

###############################################################################
# Logs & debug info
###############################################################################
*.log
.log*
yarn-error.log
.pnpm-debug.log
.pnpm-debug.log_
vite*.config.ts.timestamp*
.eslintcache
.nyc_output/
.aiignore
.aider*
!.aiderignore

###############################################################################
# TypeScript incremental build info
###############################################################################
tsconfig.tsbuildinfo
tsconfig.*.tsbuildinfo

###############################################################################
# Test artifacts & screenshots
###############################################################################
**screenshots**
.react-router/
**/*\wsl.*
**/coverage

###############################################################################
