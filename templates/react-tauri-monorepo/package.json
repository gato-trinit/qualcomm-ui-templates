    "@qualcomm-ui/eslint-plugin-react": "^1.2.2",
    "@qualcomm-ui/oxfmt-config": "^1.0.1",
    "@qualcomm-ui/tsconfig": "^2.1.1",
    "@qualcomm-ui/utils": "^1.3.2",
    "@tauri-apps/cli": "2.11.2",
    "@types/node": "24.12.4",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
