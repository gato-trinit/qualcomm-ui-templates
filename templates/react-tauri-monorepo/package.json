{
  "name": "@qui/react-tauri-vite-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "tauri dev",
    "lint": "turbo run lint",
    "lint:ci": "turbo run lint --continue",
    "lint:cache": "eslint --quiet --cache",
    "test": "turbo run test --env-mode=loose",
    "test:ci": "turbo run test:ci --env-mode=loose",
    "update-qui": "ncu --deep --filter '@qualcomm-ui/*' -u",
    "react-app": "pnpm -C packages/react-app",
    "update-dependencies": "ncu --cooldown 1d --target minor --deep -u"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@qualcomm-ui/eslint-config-mdx": "^3.0.3",
    "@qualcomm-ui/eslint-config-react": "^2.0.0",
    "@qualcomm-ui/eslint-config-typescript": "^3.0.0",
    "@qualcomm-ui/eslint-plugin-react": "^1.2.2",
    "@qualcomm-ui/oxfmt-config": "^1.0.1",
    "@qualcomm-ui/tsconfig": "^2.1.1",
    "@tauri-apps/cli": "2.11.2",
    "@types/node": "24.12.4",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "globals": "16.5.0",
    "npm-check-updates": "22.1.1",
    "npm-run-all2": "8.0.4",
    "oxfmt": "^0.54.0",
    "syncpack": "15.3.1",
    "tailwindcss": "4.3.0",
    "turbo": "2.9.14",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.2",
    "vite": "8.0.14"
  },
  "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215"
}
