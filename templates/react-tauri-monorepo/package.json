{
  "name": "@qui/react-tauri-vite-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "tauri dev",
    "lint": "turbo run lint",
    "lint:ci": "turbo run lint --continue",
    "lint:cache": "eslint --quiet --cache",
    "test": "turbo run test --env-mode=loose",
    "test:ci": "turbo run test:ci --env-mode=loose",
    "update-qui": "ncu --deep --filter '@qualcomm-ui/*' -u",
