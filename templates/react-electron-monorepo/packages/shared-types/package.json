{
  "name": "@project/shared-types",
  "version": "0.0.1",
  "description": "Type definitions and shared utilities for the serverside API in the Electron package.",
  "author": "Ryan Bower",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "run-s clean compile",
    "clean": "shx rm -rf dist",
    "compile": "run-p build:js build:types",
    "build:js": "node --import=tsx build.ts",
    "build:types": "tsc -b tsconfig.lib.json --force",
    "dev": "run-p watch:js watch:types",
    "watch:js": "pnpm build:js --watch",
    "watch:types": "pnpm build:types -w --preserveWatchOutput",
    "lint": "eslint --quiet"
  },
  "devDependencies": {
    "@qualcomm-ui/esbuild": "^1.0.5",
    "@qualcomm-ui/tsconfig": "^2.1.1",
    "@types/node": "24.12.4",
    "esbuild": "0.27.7",
    "npm-run-all2": "8.0.4",
    "shx": "0.4.0",
    "tsx": "4.22.3",
    "typescript": "5.9.3"
  }
}
