{
  "name": "@project/react-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:site": "vite -c vite.config.ts --host --clearScreen=false",
    "dev:ts": "tsc -b tsconfig.lib.json -w --preserveWatchOutput --force",
    "dev": "run-p dev:site dev:ts",
    "build": "tsc -b tsconfig.lib.json --force && vite build",
    "lint": "eslint --quiet",
    "preview": "vite preview -c vite.config.ts",
    "typecheck": "tsc -b tsconfig.lib.json --force"
  },
  "dependencies": {
    "@project/shared-types": "workspace:*",
    "@qualcomm-ui/core": "^1.11.1",
    "@qualcomm-ui/dom": "^1.1.2",
    "@qualcomm-ui/qds-core": "^1.28.2",
    "@qualcomm-ui/react": "^1.22.2",
    "@qualcomm-ui/react-core": "^1.5.2",
    "@qualcomm-ui/tailwind-plugin": "^1.7.1",
    "@qualcomm-ui/utils": "^1.3.0",
    "@tanstack/react-virtual": "3.13.25",
    "lucide-react": "1.16.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router": "7.15.1"
  },
  "devDependencies": {
    "@qualcomm-ui/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "24.12.4",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.4.27",
    "postcss": "8.5.15",
    "shx": "0.4.0",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3",
    "vite": "8.0.14"
  }
}
