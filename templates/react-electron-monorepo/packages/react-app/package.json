{
  "name": "@project/react-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:site": "vite -c vite.config.ts --host --clearScreen=false",
    "dev:ts": "tsc -b tsconfig.lib.json -w --preserveWatchOutput --force",
    "dev": "run-p dev:site dev:ts",
    "build": "tsc -b tsconfig.lib.json --force && vite build",
    "lint": "eslint --quiet",
    "preview": "vite preview -c vite.config.ts",
    "typecheck": "tsc -b tsconfig.lib.json --force"
  },
  "dependencies": {
    "@project/shared-types": "workspace:*",
    "@qualcomm-ui/core": "^1.6.1",
    "@qualcomm-ui/dom": "^1.0.10",
    "@qualcomm-ui/qds-core": "^1.21.1",
    "@qualcomm-ui/react": "^1.16.1",
    "@qualcomm-ui/react-core": "^1.3.4",
    "@qualcomm-ui/tailwind-plugin": "^1.7.0",
    "@qualcomm-ui/utils": "^1.2.1",
    "@tanstack/react-virtual": "~3.13.12",
    "lucide-react": "~0.554.0",
    "react": "~19.2.4",
    "react-dom": "~19.2.4",
    "react-router": "~7.13.2"
  },
  "devDependencies": {
    "@qualcomm-ui/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "~4.2.2",
    "@types/node": "^24",
    "@types/react": "~19.2.14",
    "@types/react-dom": "~19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "shx": "^0.4.0",
    "tailwindcss": "~4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3"
  }
}
