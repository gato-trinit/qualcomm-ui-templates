{
  "name": "@qui/react-electron-vite-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "turbo run build",
    "build:ci": "turbo run build",
    "dev": "turbo run dev",
    "dev:ui": "pnpm dev --filter='!@project/electron-app'",
    "dev:electron": "pnpm run -C packages/electron-app dev",
    "package": "turbo run package",
    "lint": "turbo run lint",
    "lint:ci": "turbo run lint --continue",
    "lint:cache": "eslint --quiet --cache",
    "test": "turbo run test --env-mode=loose",
    "test:ci": "turbo run test:ci --env-mode=loose",
    "release": "turbo run make",
    "bundle": "run-s build package",
    "update-qui": "ncu --deep --filter '@qualcomm-ui/*' -u",
    "electron-app": "pnpm -C packages/electron-app",
    "react-app": "pnpm -C packages/react-app",
    "shared-types": "pnpm -C packages/shared-types",
    "update-dependencies": "ncu --cooldown 1d --target minor --deep -u"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@qualcomm-ui/eslint-config-mdx": "^3.0.1",
    "@qualcomm-ui/eslint-config-react": "^1.1.1",
    "@qualcomm-ui/eslint-config-typescript": "^2.0.0",
    "@qualcomm-ui/eslint-plugin-react": "^1.2.0",
    "@qualcomm-ui/tsconfig": "^2.0.0",
    "@types/node": "24.12.4",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "globals": "16.5.0",
    "npm-check-updates": "22.1.1",
    "prettier-plugin-tailwindcss": "0.8.0",
    "npm-run-all2": "8.0.4",
    "syncpack": "14.2.1",
    "tailwindcss": "4.3.0",
    "turbo": "2.9.14",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.2",
    "vite": "8.0.14"
  },
  "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215"
}
