{
  "name": "qui-typescript-template",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "types": "./dist/stub.d.ts",
  "exports": {
    "./*": {
      "types": "./dist/*/index.d.ts",
      "import": "./dist/*/index.js",
      "default": "./dist/*/index.js"
    }
  },
  "scripts": {
    "clean": "shx rm -rf dist build",
    "dev": "run-p watch:js watch:ts",
    "build": "run-s clean build:js build:ts",
    "build:js": "tsx build.ts",
    "build:ts": "tsc -b tsconfig.lib.json",
    "watch:js": "tsx build.ts --watch",
    "watch:ts": "pnpm build:ts -w --preserveWatchOutput",
    "lint": "eslint --quiet"
  },
  "dependencies": {
    "@qualcomm-ui/utils": "^1.3.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@qualcomm-ui/esbuild": "^1.0.5",
    "@qualcomm-ui/eslint-config-typescript": "^2.0.0",
    "@qualcomm-ui/tsconfig": "^2.0.0",
    "@types/node": "24.12.4",
    "eslint": "9.39.4",
    "globals": "16.5.0",
    "npm-run-all2": "8.0.4",
    "shx": "0.4.0",
    "tsx": "4.22.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.49.0",
    "vite": "8.0.14",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.7"
  },
  "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215"
}
