{
  "name": "qui-typescript-template",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "types": "./dist/stub.d.ts",
  "exports": {
    "./*": {
      "types": "./dist/*/index.d.ts",
      "import": "./dist/*/index.js",
      "default": "./dist/*/index.js"
    }
  },
  "scripts": {
    "clean": "shx rm -rf dist node_modules/.tmp",
    "dev": "run-p watch:js watch:ts",
    "build": "run-s clean build:js build:ts",
    "build:js": "tsx build.ts",
    "build:ts": "tsc -b tsconfig.lib.json",
    "watch:js": "tsx build.ts --watch",
    "watch:ts": "pnpm build:ts -w --preserveWatchOutput",
    "lint": "eslint --quiet",
    "update-dependencies": "ncu --cooldown 1d --target minor -u"
  },
  "dependencies": {
    "@qualcomm-ui/utils": "^1.3.2"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@qualcomm-ui/esbuild": "^1.0.5",
    "@qualcomm-ui/eslint-config-typescript": "^3.0.0",
    "@qualcomm-ui/oxfmt-config": "^1.0.1",
    "@qualcomm-ui/tsconfig": "^2.1.1",
    "@types/node": "24.12.4",
    "esbuild": "0.27.7",
    "eslint": "9.39.4",
    "globals": "16.5.0",
    "npm-check-updates": "22.1.1",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.54.0",
    "shx": "0.4.0",
    "tsx": "4.22.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.2",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
