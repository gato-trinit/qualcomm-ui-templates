{
  "extends": "@qualcomm-ui/tsconfig/tsconfig.angular-lib.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "build",
    "rootDir": "./src",
    "tsBuildInfoFile": "build/.tmp/.tsbuildinfo-lib"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "typeCheckHostBindings": true,
    "strictTemplates": true
  },
  "include": ["./src"],
  "exclude": ["./src/**/*.spec.ts"]
}
