{
  "name": "qui-templates",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "check-all": "ncu -c 1 --deep",
    "update-all": "npm run check-all -u",
    "check-qui": "ncu --deep --filter '@qualcomm-ui/*'",
    "update-qui": "npm run check-qui -u",
    "lint-dependencies": "syncpack lint --source 'templates/*/package.json' --source 'templates/*/packages/*/package.json'",
    "fix-dependencies": "syncpack fix --source 'templates/*/package.json' --source 'templates/*/packages/*/package.json'"
  },
  "devDependencies": {
    "npm-check-updates": "22.2.1",
    "syncpack": "15.3.1",
    "typescript": "6.0.2"
  }
}
